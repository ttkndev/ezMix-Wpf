<Window x:Class="ezMix.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ezMix.Views"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Title="Phần mềm trộn đề - ezMix" 
        MinWidth="1024" MinHeight="768">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Cột trái: Sidebar -->
        <DockPanel Grid.Column="0" Background="{StaticResource PrimaryBrush}" Width="{Binding MenuWidth}">
            <!-- Hàng 1: Logo + ezMix + nút thu gọn -->
            <Grid DockPanel.Dock="Top" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo chữ ezMix -->
                <TextBlock Text="ezMix" Margin="10,0,0,0"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsMenuExpanded, Converter={StaticResource BoolToHiddenConverter}}"/>

                <!-- Nút thu gọn/mở rộng -->
                <Button Grid.Column="1"
                        Command="{Binding ToggleMenuCommand}"
                        ToolTip="Thu gọn/Mở rộng menu"
                        Width="30" Height="30" Margin="10"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <!-- Vòng tròn nền -->
                                <Ellipse Fill="Transparent" Stroke="White" StrokeThickness="2"/>
                                <!-- Nội dung nút -->
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                    <!-- Nội dung hiển thị -->
                    <Viewbox Stretch="Uniform">
                        <TextBlock Text="≡" 
                                   Padding="0,0,0,3"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Viewbox>
                </Button>
            </Grid>

            <!-- Hàng 2: Menu -->
            <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                <!-- Nút Home -->
                <Button Command="{Binding ChangeViewCommand}" CommandParameter="Home" BorderThickness="0" ToolTip="Trang chủ"
                        Background="Transparent" Foreground="White"
                        HorizontalContentAlignment="Stretch"
                        Padding="10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🏠" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Trang chủ" FontSize="16" VerticalAlignment="Center" Visibility="{Binding IsMenuExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Button>

                <!-- Nút Mix -->
                <Button Command="{Binding ChangeViewCommand}" CommandParameter="Mix" 
                        FontSize="18" BorderThickness="0" ToolTip="Trộn đề"
                        Background="Transparent" Foreground="White" HorizontalContentAlignment="Stretch" Padding="10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🧩" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Trộn đề" FontSize="16" VerticalAlignment="Center" Visibility="{Binding IsMenuExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Button>

                <!-- Nút Utility -->
                <Button Command="{Binding ChangeViewCommand}" CommandParameter="Utility" 
                        FontSize="18" BorderThickness="0" ToolTip="Tiện ích"
                        Background="Transparent" Foreground="White" HorizontalContentAlignment="Stretch" Padding="10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Tiện ích" FontSize="16" VerticalAlignment="Center" Visibility="{Binding IsMenuExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Hàng 3: Phiên bản -->
            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding VersionText}"
                       Foreground="White"
                       FontSize="14"
                       Margin="10"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center"/>
        </DockPanel>

        <!-- Cột phải: Nội dung -->
        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Hàng 1: tên chức năng -->
                <RowDefinition Height="*"/>
                <!-- Hàng 2: nội dung -->
                <RowDefinition Height="Auto"/>
                <!-- Hàng 3: tác giả -->
            </Grid.RowDefinitions>

            <!-- Hàng 1: Thanh Title + tên chức năng -->
            <Grid Grid.Row="0" Background="#cfe8fc">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Chức năng đang chọn -->
                    <ColumnDefinition Width="*"/>
                    <!-- Title giữa -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Nút control -->
                </Grid.ColumnDefinitions>

                <!-- Tên chức năng từ menu -->
                <TextBlock Grid.Column="0" Text="{Binding SelectedMenuText}" Margin="10,5"
               FontSize="15" Foreground="{StaticResource PrimaryBrush}"
               VerticalAlignment="Center"/>

                <!-- Title nằm giữa -->
                <TextBlock Grid.Column="1" Text="Phiên bản thử nghiệm" 
               HorizontalAlignment="Center" VerticalAlignment="Center"
               FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>

            </Grid>

            <!-- Hàng 2: Nội dung UserControl -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>

            <!-- Hàng 3: Thông tin tác giả -->
            <Grid Grid.Row="2" Background="#cfe8fc" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBlock Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Padding="10" HorizontalAlignment="Center" FontSize="15">
                    <Run Text="💬 Nhóm hỗ trợ: "/>
                    <Hyperlink Command="{Binding OpenUrlCommand}" 
                               CommandParameter="https://zalo.me/g/rxncpe995"
                               FontWeight="Bold">
                        Zalo
                    </Hyperlink>
                </TextBlock>
            </Grid>

        </Grid>
    </Grid>
</Window>
