<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="DashboardTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource DefaultFontSize}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardCount" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
        <Setter Property="FontSize" Value="20"/>
        <!-- có thể tạo resource riêng nếu dùng nhiều -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    
    <Style x:Key="DashboardIcon" TargetType="Viewbox">
        <!-- Viewbox để icon tự co giãn -->
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
    
    <Style x:Key="DashboardPathIcon" TargetType="Path">
        <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DashboardImageIcon" TargetType="Image">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="{StaticResource DefaultControlMargin}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Stretch" Value="Uniform"/>
    </Style>
    
    <!--Cách dùng
    <Border Style="{StaticResource DashboardCard}">
        <StackPanel>
            <Path Style="{StaticResource DashboardPathIcon}" 
              Data="M10,20 L20,30 L30,10 Z"/>
            <TextBlock Style="{StaticResource DashboardTitle}" Text="Orders"/>
            <TextBlock Style="{StaticResource DashboardCount}" Text="128"/>
        </StackPanel>
    </Border>-->
</ResourceDictionary>